# Environment Variables for AssetFlow Backend
# Copy this file to .env and fill in your values

# =============================================
# APPLICATION
# =============================================
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# =============================================
# DATABASE
# =============================================
DATABASE_URL="postgresql://assetflow:assetflow123@localhost:5432/assetflow_db?schema=public"

# =============================================
# JWT AUTHENTICATION
# =============================================
JWT_ACCESS_SECRET=your_super_secret_jwt_access_key_change_in_production_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_key_change_in_production_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# =============================================
# CORS
# =============================================
CORS_ORIGIN=http://localhost:3000

# =============================================
# RATE LIMITING
# =============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================
# BCRYPT
# =============================================
BCRYPT_ROUNDS=12

# =============================================
# LOGGING
# =============================================
LOG_LEVEL=debug
